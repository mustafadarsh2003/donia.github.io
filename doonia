              <h4 className="text-xl lg:text-2xl font-black text-rose-500 flex items-center space-x-2 space-x-reverse">
                <svg xmlns="http://www.w3.org/2000/svg" className="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
                  <path strokeLinecap="round" strokeLinejoin="round" d="M12 9v3m0 0v3m0-3h3m-3 0H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>تسجيل ذكرى جديدة مع بابا</span>
              </h4>
              <p className="text-xs text-slate-400">اكتبي هنا اليوم السعيد أو المناسبة عشان نفضل فاكرينها سوا يا روحي.</p>
            </div>

            <form onSubmit={handleAddNewMemory} className="space-y-5">
              
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div className="space-y-2">
                  <label className="block text-xs font-bold text-slate-400">تاريخ الذكرى</label>
                  <input
                    type="date"
                    required
                    value={newDate}
                    onChange={(e) => setNewDate(e.target.value)}
                    className={`w-full px-4 py-3 ${isDarkMode ? 'bg-[#180d32] border-white/10 text-white' : 'bg-white border-pink-200 text-slate-800'} rounded-xl focus:outline-none focus:ring-2 focus:ring-rose-500/50`}
                  />
                </div>

                <div className="space-y-2">
                  <label className="block text-xs font-bold text-slate-400">الرمز التعبيري للذكرى</label>
                  <select
                    value={newIcon}
                    onChange={(e) => setNewIcon(e.target.value)}
                    className={`w-full px-4 py-3 ${isDarkMode ? 'bg-[#1e1335] border-white/10 text-white' : 'bg-white border-pink-200 text-slate-800'} rounded-xl focus:outline-none focus:ring-2 focus:ring-rose-500/50 text-right`}
                  >
                    <option value="heart">❤️ حب جوهري وحنان</option>
                    <option value="sparkles">✨ نجوم ولمعة</option>
                    <option value="gift">🎁 هدية حلوة</option>
                    <option value="star">⭐ علامة بابا الذهبية</option>
                  </select>
                </div>
              </div>

              <div className="space-y-2">
                <label className="block text-xs font-bold text-slate-400">عنوان الذكرى</label>
                <input
                  type="text"
                  required
                  placeholder="مثال: يوم ما كسبت بابا في اللعبة 🏆"
                  value={newTitle}
                  onChange={(e) => setNewTitle(e.target.value)}
                  className={`w-full px-4 py-3 ${isDarkMode ? 'bg-slate-900/60 border-white/10 text-white' : 'bg-white border-pink-200 text-slate-800'} rounded-xl focus:outline-none focus:ring-2 focus:ring-rose-500/50 text-right`}
                />
              </div>

              <div className="space-y-2">
                <label className="block text-xs font-bold text-slate-400">إيه اللي حصل في اليوم ده؟</label>
                <textarea
                  required
                  rows={3}
                  placeholder="اكتبي التفاصيل اللي حابة نفضل فاكرينها سوا..."
                  value={newDesc}
                  onChange={(e) => setNewDesc(e.target.value)}
                  className={`w-full px-4 py-3 ${isDarkMode ? 'bg-slate-900/60 border-white/10 text-white' : 'bg-white border-pink-200 text-slate-800'} rounded-xl focus:outline-none focus:ring-2 focus:ring-rose-500/50 resize-none text-right`}
                />
              </div>

              <div className="flex space-x-3 space-x-reverse pt-2">
                <button
                  type="submit"
                  className="flex-1 py-3 bg-gradient-to-r from-pink-500 to-rose-600 hover:from-pink-600 hover:to-rose-700 text-white font-black rounded-xl shadow-[0_4px_20px_rgba(244,63,94,0.3)] transition-all hover:scale-[1.02]"
                >
                  حفظ في ذاكرتنا المشتركة 💖
                </button>
                <button
                  type="button"
                  onClick={() => setShowMemoryModal(false)}
                  className="flex-1 py-3 bg-white/5 hover:bg-white/10 text-slate-300 font-bold rounded-xl transition-all border border-white/10 text-center"
                >
                  إلغاء
                </button>
              </div>
            </form>
          </div>
        </div>
      )}

    </div>
  );
}
