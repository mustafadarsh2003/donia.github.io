  const resetCardGame = () => {
    const baseIcons = ['🧁', '👑', '🌈', '🍭'];
    const pairIcons = [...baseIcons, ...baseIcons];
    const shuffled = pairIcons
      .map((icon, idx) => ({ id: `${idx}-${Date.now()}`, icon }))
      .sort(() => Math.random() - 0.5);

    setCards(shuffled);
    setFlippedCards([]);
    setMatchedCards([]);
  };

  const handleCardClick = (idx) => {
    if (flippedCards.includes(idx) || matchedCards.includes(idx) || flippedCards.length >= 2) return;

    const newFlipped = [...flippedCards, idx];
    setFlippedCards(newFlipped);

    if (newFlipped.length === 2) {
      const [firstIdx, secondIdx] = newFlipped;
      if (cards[firstIdx].icon === cards[secondIdx].icon) {
        setTimeout(() => {
          const newMatched = [...matchedCards, firstIdx, secondIdx];
