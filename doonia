  const [sudokuFeedback, setSudokuFeedback] = useState('');

  // Clock Update Function
  const updateClock = () => {
    const startDate = new Date('April 29, 2026 00:00:00').getTime();
    const now = new Date().getTime();
    const diff = now - startDate;

    if (diff <= 0) {
      setTimeElapsed({ years: 0, months: 0, days: 0, hours: 0, minutes: 0, seconds: 0 });
      return;
    }

    const s = 1000;
    const m = s * 60;
    const h = m * 60;
    const day = h * 24;
    const month = day * 30.44; 
    const year = day * 365.25; 

    const years = Math.floor(diff / year);
    const months = Math.floor((diff % year) / month);
    const days = Math.floor((diff % month) / day);
    const hours = Math.floor((diff % day) / h);
    const minutes = Math.floor((diff % h) / m);
    const seconds = Math.floor((diff % m) / s);

    setTimeElapsed({ years, months, days, hours, minutes, seconds });
  };

