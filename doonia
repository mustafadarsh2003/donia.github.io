  const sudokuInitial = [
    [1, null, 3, 4],
    [3, 4, null, 1],
    [null, 1, 4, 3],
    [4, 3, 1, null]
  ];
  const sudokuSolution = [
    [1, 2, 3, 4],
    [3, 4, 2, 1],
    [2, 1, 4, 3],
    [4, 3, 1, 2]
  ];
